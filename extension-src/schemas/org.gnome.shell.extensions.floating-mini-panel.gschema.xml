<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="org.gnome.shell.extensions.floating-mini-panel.orientation">
    <value nick="horizontal" value="0"/>
    <value nick="left" value="1"/>
    <value nick="right" value="2"/>
  </enum>
  <schema path="/org/gnome/shell/extensions/floating-mini-panel/" id="org.gnome.shell.extensions.floating-mini-panel">
    <key name="state" type="i">
      <default>1</default>
      <summary>Panel State</summary>
      <description>
        0 = Off, 1 = On, 2 = Auto
      </description>
    </key>
    <key name="pos-x" type="i">
      <default>0</default>
      <summary>X Position</summary>
      <description>
        Horizontal Position of floating-mini-panel.
      </description>
    </key>
    <key name="pos-y" type="i">
      <default>0</default>
      <summary>Y Position</summary>
      <description>
        Vertical Position of floating-mini-panel.
      </description>
    </key>
    <key name="aligned" type="i">
      <default>5</default>
      <summary>Aligned</summary>
      <description>
        Is floating-mini-panel is aligned to a default position (NONE: 0, TOP: 1, BOTTOM: 2, LEFT: 4, RIGHT: 8, CENTER: 16).
      </description>
    </key>
    <key name="orientation" enum="org.gnome.shell.extensions.floating-mini-panel.orientation">
      <default>'horizontal'</default>
      <summary>Panel orientation</summary>
      <description>
        Panel layout: 'horizontal', or a vertical strip with the graphs rotated
        'left' (counter-clockwise, time bottom-to-top) or 'right' (clockwise,
        time top-to-bottom).
      </description>
    </key>
    <key name="content-padding" type="i">
      <default>0</default>
      <summary>Content padding</summary>
      <description>
        Padding in pixels around the widgets' working body (the space between the
        panel edge and its contents).
      </description>
    </key>
    <key name="open" type="b">
      <default>false</default>
      <summary>Drawer opened</summary>
      <description>
        Is 3rd party indicator drawer opened.
      </description>
    </key>
    <key name="always" type="as">
      <default>[]</default>
      <summary>Always visible</summary>
      <description>
        Always visible 3rd party extension indicators.
      </description>
    </key>
  </schema>
</schemalist>
